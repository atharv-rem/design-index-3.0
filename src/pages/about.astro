---
import "../styles/global.css";

export const prerender = false;

const title = "About Athar | Design Index";
const description =
  "Learn more about Athar, a developer focused on frontend experiences, clean UI, and practical modern web tools.";
const canonicalUrl = Astro.url.href;
const ogImage = new URL("/favicon.svg", Astro.url).href;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="robots" content="index,follow" />
		<link rel="canonical" href={canonicalUrl} />

		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={ogImage} />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />
	</head>
	<body>
		<main class="min-h-screen bg-slate-50 px-6 py-12 text-slate-800">
			<section class="mx-auto max-w-3xl rounded-2xl border border-slate-200 bg-white p-8 shadow-sm md:p-10">
				<p class="mb-3 text-sm font-semibold uppercase tracking-[0.2em] text-slate-500">About Me</p>
				<h1 class="text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">Hi, I'm Athar</h1>

				<p class="mt-6 text-base leading-7 text-slate-700">
					I'm a curious developer who enjoys building simple, useful web experiences. I like turning ideas
					into clean interfaces and learning new tools along the way.
				</p>

				<p class="mt-4 text-base leading-7 text-slate-700">
					When I'm not coding, I spend time exploring design inspiration, improving my workflow, and working
					on projects that help me grow as a creator.
				</p>

				<div class="mt-8 grid gap-4 sm:grid-cols-2">
					<div class="rounded-xl bg-slate-100 p-4">
						<h2 class="text-sm font-semibold text-slate-900">What I Enjoy</h2>
						<p class="mt-2 text-sm leading-6 text-slate-700">Frontend development, UI design, and shipping practical ideas.</p>
					</div>
					<div class="rounded-xl bg-slate-100 p-4">
						<h2 class="text-sm font-semibold text-slate-900">Currently Learning</h2>
						<p class="mt-2 text-sm leading-6 text-slate-700">Astro, Tailwind CSS, and building fast modern websites.</p>
					</div>
			</div>
			</section>
		</main>
	</body>
</html>