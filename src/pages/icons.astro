---
import HomescreenLayout from "../layouts/homescreen.astro";
import ToolsGrid from "../components/tools-grid";
import { supabase } from "@/lib/supabase";
const { data: tools, error } = await supabase.from("design_index").select("*").eq("category", "icon");
---

<HomescreenLayout title="Icon Libraries for UI and Product Design | Design Index" description="Explore curated icon libraries with line, solid, duotone, and animated icon styles for digital products." keywords="icons, icon libraries, UI icons, product icons, animated icons, SVG icons" backgroundVariant="slate" floatingNavbarMode="search">
	<main class="mt-[50px] px-[20px]">
		<section>
			<div>
				<h1 class="mt-3 font-departure font-regular text-4xl leading-none text-white md:text-[40px]">ICONS</h1>
				<p class="mt-4 rounded-lg bg-[#181818] px-[10px] py-[5px] font-departure text-sm leading-[20px] text-zinc-300 md:text-base">
					A versatile collection of icon libraries covering diverse styles, categories, and use cases. Whether you need minimal line icons, bold glyphs, playful or animated icons, this section helps you communicate ideas clearly and enhance user interaction with visual clarity.
				</p>
				<ToolsGrid client:only="react" category="icons" tools={tools ?? []} />
			</div>
		</section>
	</main>
</HomescreenLayout>
