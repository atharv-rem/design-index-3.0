---
import HomescreenLayout from "../layouts/homescreen.astro";
import ToolsGrid from "../components/tools-grid";
import { getToolsByCategory } from "@/lib/get-tool-by-category";

const tools = await getToolsByCategory("icon");

if (Astro.cache.enabled) {
	Astro.cache.set({
		maxAge: 3600,
		tags: ["icons-page"],
	});
}
---

<HomescreenLayout title="Icon Libraries for UI and Product Design | Design Index" description="Explore curated icon libraries with line, solid, duotone, and animated icon styles for digital products." keywords="icons, icon libraries, UI icons, product icons, animated icons, SVG icons" backgroundVariant="slate">
	<main class="mt-[40px] md:mt-[30px] px-[20px]">
		<section>
			<div>
				<h1 class="mt-3 font-departure font-regular text-4xl leading-none theme-text-primary md:text-[40px]">ICONS</h1>
				<p class="hidden md:block mt-4 rounded-lg border border-[var(--app-border)] bg-[var(--app-surface-soft)] px-[10px] py-[5px] font-departure text-sm leading-[20px] theme-text-muted md:text-base">
					A versatile collection of icon libraries covering diverse styles, categories, and use cases. Whether you need minimal line icons, bold glyphs, playful or animated icons, this section helps you communicate ideas clearly and enhance user interaction with visual clarity.
				</p>
				<p class="block md:hidden mt-4 rounded-lg border border-[var(--app-border)] bg-[var(--app-surface-soft)] px-[10px] py-[5px] font-departure text-sm leading-[20px] theme-text-muted md:text-base">
					A versatile collection of icon libraries spanning styles and use cases. From minimal lines to bold or animated icons, find the right visuals to enhance clarity and user interaction
				</p>
				<ToolsGrid client:load category="icon" initialTools={tools} />
			</div>
		</section>
	</main>
</HomescreenLayout>
