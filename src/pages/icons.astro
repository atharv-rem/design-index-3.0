---
import HomescreenLayout from "../layouts/homescreen.astro";
---

<HomescreenLayout title="Icons | Design Index" description="Explore curated icon resources." backgroundVariant="slate">
	<main class="min-h-screen px-6 py-12 text-white md:pl-72">
		<section class="mx-auto max-w-4xl rounded-2xl bg-black/60 p-8 backdrop-blur-sm">
			<h1 class="font-kal text-3xl">Icons</h1>
			<p class="mt-3 text-sm text-zinc-300">This page is ready. Add your curated icon tools here.</p>
		</section>
	</main>
</HomescreenLayout>
