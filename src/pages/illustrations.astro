---
import HomescreenLayout from "../layouts/homescreen.astro";
import ToolsGrid from "../components/tools-grid";
import { getToolsByCategory } from "@/lib/get-tool-by-category";

const tools = await getToolsByCategory("illustration");
if (Astro.cache.enabled) {
	Astro.cache.set({
		maxAge: 3600,
		tags: ["illustrations-page"],
	});
}
---

<HomescreenLayout title="Illustration Libraries and Assets | Design Index" description="Explore curated illustration libraries and assets for websites, apps, branding, and marketing designs." keywords="illustrations, illustration libraries, vector illustrations, 3D illustrations, design assets" backgroundVariant="slate">
	<main class="mt-[40px] md:mt-[30px] px-[20px]">
		<section>
			<div>
				<h1 class="mt-3 font-departure font-regular text-4xl leading-none theme-text-primary md:text-[40px]">ILLUSTRATIONS</h1>
				<p class="hidden md:block mt-4 rounded-lg border border-[var(--app-border)] bg-[var(--app-surface-soft)] px-[10px] py-[5px] font-departure text-sm leading-[20px] theme-text-muted md:text-base">
					A rich archive of illustrations ranging from minimal flat styles to detailed artworks. Use these visual assets to add depth, storytelling, and emotional warmth to your projects, making them more engaging, memorable, and human-centered.
				</p>
				<p class="block md:hidden mt-4 rounded-lg border border-[var(--app-border)] bg-[var(--app-surface-soft)] px-[10px] py-[5px] font-departure text-sm leading-[20px] theme-text-muted md:text-base">
					A rich archive of illustrations—from minimal to detailed—to add depth, emotion, and storytelling to your projects. Make your work more engaging, memorable, and human-centered.
				</p>
				<ToolsGrid client:load category="illustration" initialTools={tools} />
			</div>
		</section>
	</main>
</HomescreenLayout>
