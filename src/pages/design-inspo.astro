---
import HomescreenLayout from "../layouts/homescreen.astro";
import ToolsGrid from "../components/tools-grid";
import { supabase } from "@/lib/supabase";

const { data: tools } = await supabase.from("design_index").select("*").eq("category", "design_inspiration");
---

<HomescreenLayout title="Design Inspiration Websites and Galleries | Design Index" description="Explore curated design inspiration websites and galleries for UI, branding, layouts, and visual direction." keywords="design inspiration, UI inspiration, web design galleries, creative inspiration, visual design references" backgroundVariant="slate" floatingNavbarMode="search">
	<main class="mt-[50px] px-[20px]">
		<section>
			<div>
				<h1 class="mt-3 font-departure font-regular text-4xl leading-none text-white md:text-[40px]">DESIGN INSPIRATION</h1>
				<p class="mt-4 rounded-lg bg-[#181818] px-[10px] py-[5px] font-departure text-sm leading-[20px] text-zinc-300 md:text-base">
					Thoughtfully assembled gallery of visual inspiration across web, mobile, print, and branding. Discover cutting-edge layouts, creative UI patterns, and standout visuals to spark ideas, refine your style, and fuel your creative momentum.
				</p>
				<ToolsGrid client:load category="design-inspo" initialTools={tools ?? []} />
			</div>
		</section>
	</main>
</HomescreenLayout>
