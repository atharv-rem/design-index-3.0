---
import HomescreenLayout from "../layouts/homescreen.astro";
import ToolsGrid from "../components/tools-grid";
import { getToolsByCategory } from "@/lib/get-tool-by-category";

const tools = await getToolsByCategory("mockup");

if (Astro.cache.enabled) {
	Astro.cache.set({
		maxAge: 86400,
		swr: 43200,
		tags: ["mockups-page"],
	});
}
---

<HomescreenLayout title="Mockups | Design Index" description="Explore curated mockup resources for devices, branding, packaging, and product presentations." keywords="mockups, device mockups, branding mockups, packaging mockups, product presentation resources" backgroundVariant="slate">
	<main class="mt-[12px] px-[20px]">
		<section>
			<div>
				<h1 class="font-google font-medium tracking-[0.05rem] text-4xl leading-none theme-text-primary md:text-[40px]">
					Mockups
				</h1>
				<p class="hidden md:block mt-3 font-rethink text-[20px] leading-[18px] theme-text-muted md:text-base font-medium">
					A curated library of high-quality device and product mockups to showcase your designs in real-world contexts. From phones and laptops to packaging and apparel, this section offers versatile templates to help you present your work with professionalism, clarity, and impact.
				</p>
				<p class="block md:hidden mt-3 font-rethink text-[15px] leading-[18px] theme-text-muted md:text-base font-medium">
					A curated library of high-quality mockups to showcase designs in real-world settings. From devices to packaging, present your work with clarity, professionalism, and impact.
				</p>
				<ToolsGrid client:load category="mockup" initialTools={tools} />
			</div>
		</section>
	</main>
</HomescreenLayout>
