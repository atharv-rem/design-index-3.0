---
import HomescreenLayout from "../layouts/homescreen.astro";
import ToolsGrid from "../components/tools-grid";
import { getToolsByCategory } from "@/lib/get-tool-by-category";

const tools = await getToolsByCategory("mockup");

if (Astro.cache.enabled) {
	Astro.cache.set({
		maxAge: 3600,
		tags: ["mockups-page"],
	});
}
---

<HomescreenLayout title="Mockup Resources for Designers | Design Index" description="Explore curated mockup resources for devices, branding, packaging, and product presentations." keywords="mockups, device mockups, branding mockups, packaging mockups, product presentation resources" backgroundVariant="slate">
	<main class="mt-[40px] md:mt-[30px] px-[20px]">
		<section>
			<div>
				<h1 class="mt-3 font-departure font-regular text-4xl leading-none theme-text-primary md:text-[40px]">MOCKUPS</h1>
				<p class="hidden md:block mt-4 rounded-lg border border-[var(--app-border)] bg-[var(--app-surface-soft)] px-[10px] py-[5px] font-departure text-sm leading-[20px] theme-text-muted md:text-base">
					A curated library of high-quality device and product mockups to showcase your designs in real-world contexts. From phones and laptops to packaging and apparel, this section offers versatile templates to help you present your work with professionalism, clarity, and impact.
				</p>
				<p class="block md:hidden mt-4 rounded-lg border border-[var(--app-border)] bg-[var(--app-surface-soft)] px-[10px] py-[5px] font-departure text-sm leading-[20px] theme-text-muted md:text-base">
					A curated library of high-quality mockups to showcase designs in real-world settings. From devices to packaging, present your work with clarity, professionalism, and impact.
				</p>
				<ToolsGrid client:load category="mockup" initialTools={tools} />
			</div>
		</section>
	</main>
</HomescreenLayout>
