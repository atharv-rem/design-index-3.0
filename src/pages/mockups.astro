---
import HomescreenLayout from "../layouts/homescreen.astro";
import ToolsGrid from "../components/tools-grid";
import { supabase } from "@/lib/supabase";

const { data: tools } = await supabase.from("design_index").select("*").eq("category", "mockup");
---

<HomescreenLayout title="Mockup Resources for Designers | Design Index" description="Explore curated mockup resources for devices, branding, packaging, and product presentations." keywords="mockups, device mockups, branding mockups, packaging mockups, product presentation resources" backgroundVariant="slate" floatingNavbarMode="search">
	<main class="mt-[50px] px-[20px]">
		<section>
			<div>
				<h1 class="mt-3 font-departure font-regular text-4xl leading-none text-white md:text-[40px]">MOCKUPS</h1>
				<p class="mt-4 rounded-lg bg-[#181818] px-[10px] py-[5px] font-departure text-sm leading-[20px] text-zinc-300 md:text-base">
					A curated library of high-quality device and product mockups to showcase your designs in real-world contexts. From phones and laptops to packaging and apparel, this section offers versatile templates to help you present your work with professionalism, clarity, and impact.
				</p>
				<ToolsGrid client:load category="mockups" initialTools={tools ?? []} />
			</div>
		</section>
	</main>
</HomescreenLayout>
