---
import HomescreenLayout from "../layouts/homescreen.astro";
import { actions } from "astro:actions";

export const prerender = false;

const result = Astro.getActionResult(actions.submitFeedback);

if (result && !result.error) {
  return Astro.redirect(`${Astro.url.pathname}?success=true`);
}

let success = Astro.url.searchParams.get("success") === "true";
let errorMessage = result?.error ? result.error.message : "";
---

<HomescreenLayout
	title="Feedback | Design Index"
	description="Share feedback to help improve Design Index and make the resource directory better for designers."
	keywords="design index feedback, website feedback, design resources feedback"
	backgroundVariant="slate"
>
	<main class="mt-[40px] md:mt-[30px] px-[20px] pb-10">
		<section class="mx-auto w-full max-w-[500px] rounded-xl">
			<div>
				<h1 class="mt-3 font-rethink text-4xl leading-none theme-text-primary md:text-[40px] font-medium tracking-[0.01rem]">Feedback</h1>
				<p class="mt-3 font-rethink font-medium text-[15px] leading-[20px] theme-text-muted md:text-base">
					Tell us what is working, what feels missing, and what would make Design Index more useful in your workflow.
				</p>
			</div>

			<div class="mt-6 md:max-w-2xl">

				<form action={actions.submitFeedback} method="post">
					<div class="grid gap-4 md:grid-cols-2">
						<label class="flex flex-col gap-2 font-rethink text-sm tracking-[0.05rem] theme-text-soft">
							Name
							<input
								type="text"
								name="name"
								placeholder="Your name"
								required
								class="h-10 rounded-md border border-[var(--app-border)] bg-[var(--app-panel-contrast)] px-3 font-rethink text-sm normal-case tracking-normal theme-text-primary placeholder:theme-text-soft focus:border-[var(--app-border-strong)] focus:outline-none"
							/>
						</label>

						<label class="flex flex-col gap-2 font-rethink text-sm tracking-[0.05rem] theme-text-soft">
							Email
							<input
								type="email"
								name="email"
								placeholder="you@example.com"
								required
								class="h-10 rounded-md border border-[var(--app-border)] bg-[var(--app-panel-contrast)] px-3 font-rethink text-sm normal-case tracking-normal theme-text-primary placeholder:theme-text-soft focus:border-[var(--app-border-strong)] focus:outline-none"
							/>
						</label>
					</div>

					<label class="mt-4 flex flex-col gap-2 font-rethink text-sm tracking-[0.05rem] theme-text-soft">
						Feedback
						<textarea
							name="feedback"
							rows="6"
							placeholder="Share your thoughts..."
							required
							class="rounded-md border border-[var(--app-border)] bg-[var(--app-panel-contrast)] px-3 py-2 font-rethink text-sm normal-case tracking-normal theme-text-primary placeholder:theme-text-soft focus:border-[var(--app-border-strong)] focus:outline-none"
						></textarea>
					</label>
					{success && (
					<div class="mt-6 rfont-rethink text-sm text-emerald-600 dark:text-emerald-400">
						<p class="font-bold uppercase tracking-[0.05rem]">Feedback Sent!</p>
						<p class="mt-1 normal-case tracking-normal">Thank you for sharing your feedback. We have successfully sent an email notification to the administrator!</p>
					</div>
					)}

					{errorMessage && (
						<div class="mt-6  font-rethink text-sm text-rose-600 dark:text-rose-400">
							<p class="font-bold tracking-[0.05rem]">Submission Failed</p>
							<p class="mt-1 normal-case tracking-normal">{errorMessage}</p>
						</div>
					)}
					<button
						type="submit"
						class="mt-4 font-bold theme-button inline-flex h-10 items-center justify-center rounded-md px-4 font-rethink text-xs uppercase tracking-[0.12em]"
					>
						Send Feedback
					</button>
				</form>
			</div>
		</section>
	</main>
</HomescreenLayout>
