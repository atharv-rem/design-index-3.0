---
import HomescreenLayout from "../layouts/homescreen.astro";
---

<HomescreenLayout
	title="Feedback | Design Index"
	description="Share feedback to help improve Design Index and make the resource directory better for designers."
	keywords="design index feedback, website feedback, design resources feedback"
	backgroundVariant="slate"
>
	<main class="mt-[50px] px-[20px]">
		<section>
			<div>
				<h1 class="mt-3 font-departure font-regular text-4xl leading-none text-white md:text-[40px]">FEEDBACK</h1>
				<p class="mt-4 rounded-lg bg-[#181818] px-[10px] py-[5px] font-departure text-sm leading-[20px] text-zinc-300 md:text-base">
					Tell us what is working, what feels missing, and what would make Design Index more useful in your workflow.
				</p>
			</div>

			<form class="mt-6 rounded-lg border border-white/10 bg-[#121212] p-4 md:max-w-2xl" action="#" method="post">
				<div class="grid gap-4 md:grid-cols-2">
					<label class="flex flex-col gap-2 font-departure text-xs uppercase tracking-[0.12em] text-zinc-400">
						Name
						<input
							type="text"
							name="name"
							placeholder="Your name"
							class="h-10 rounded-md border border-white/10 bg-black px-3 font-departure text-sm normal-case tracking-normal text-white placeholder:text-zinc-500 focus:border-white/30 focus:outline-none"
						/>
					</label>

					<label class="flex flex-col gap-2 font-departure text-xs uppercase tracking-[0.12em] text-zinc-400">
						Email
						<input
							type="email"
							name="email"
							placeholder="you@example.com"
							class="h-10 rounded-md border border-white/10 bg-black px-3 font-departure text-sm normal-case tracking-normal text-white placeholder:text-zinc-500 focus:border-white/30 focus:outline-none"
						/>
					</label>
				</div>

				<label class="mt-4 flex flex-col gap-2 font-departure text-xs uppercase tracking-[0.12em] text-zinc-400">
					Feedback
					<textarea
						name="feedback"
						rows="6"
						placeholder="Share your thoughts..."
						class="rounded-md border border-white/10 bg-black px-3 py-2 font-departure text-sm normal-case tracking-normal text-white placeholder:text-zinc-500 focus:border-white/30 focus:outline-none"
					></textarea>
				</label>

				<button
					type="submit"
					class="mt-4 inline-flex h-10 items-center justify-center rounded-md border border-white/20 bg-white/5 px-4 font-departure text-xs uppercase tracking-[0.12em] text-white transition-colors hover:bg-white/10"
				>
					Send Feedback
				</button>
			</form>
		</section>
	</main>
</HomescreenLayout>
