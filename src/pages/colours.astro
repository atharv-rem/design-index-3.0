---
import HomescreenLayout from "../layouts/homescreen.astro";
import ToolsGrid from "../components/tools-grid";
import { getToolsByCategory } from "@/lib/get-tool-by-category";

const tools = await getToolsByCategory("colour");
if (Astro.cache.enabled) {
	Astro.cache.set({
		maxAge: 3600,
		swr:3600,
		tags: ["colours-page"],
	});
}
---

<HomescreenLayout
	title="Colour Tools and Palettes | Design Index"
	description="Explore curated colour palettes..."
	backgroundVariant="slate"
>
	<main class="mt-[40px] md:mt-[30px] px-[20px]">
		<section>
			<div>
				<h1 class="mt-3 font-departure font-regular text-4xl leading-none theme-text-primary md:text-[40px]">
					COLOURS
				</h1>

				<ToolsGrid
					client:load
					category="colour"
					initialTools={tools}
				/>
			</div>
		</section>
	</main>
</HomescreenLayout>
