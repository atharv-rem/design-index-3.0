---
import HomescreenLayout from "../layouts/homescreen.astro";
import ToolsGrid from "../components/tools-grid";
import { getToolsByCategory } from "@/lib/get-tool-by-category";

const tools = await getToolsByCategory("colour");
if (Astro.cache.enabled) {
	Astro.cache.set({
		maxAge: 3600,
		swr:3600,
		tags: ["colours-page"],
	});
}
---

<HomescreenLayout
	title="Colour Tools and Palettes | Design Index"
	description="Explore curated colour palettes..."
	backgroundVariant="slate"
>
	<main class="mt-[40px] md:mt-[30px] px-[20px]">
		<section>
			<div>
				<h1 class="mt-3 font-departure font-regular text-4xl leading-none theme-text-primary md:text-[40px]">
					COLOURS
				</h1>
				<p class="hidden md:block mt-4 rounded-lg border border-[var(--app-border)] bg-[var(--app-surface-soft)] px-[10px] py-[5px] font-departure text-sm leading-[20px] theme-text-muted md:text-base">
					A curated collection of colour palettes, hues, gradients and backgrounds to inspire and streamline your design process. From bold primaries to subtle pastels, this section offers a versatile range of colour resources to help you build consistent, visually appealing, and emotionally resonant design systems
				</p>
				<p class="block md:hidden mt-4 rounded-lg border border-[var(--app-border)] bg-[var(--app-surface-soft)] px-[10px] py-[5px] font-departure text-sm leading-[20px] theme-text-muted md:text-base">
					A curated collection of colour palettes, gradients, and backgrounds to inspire your design process. Explore bold to subtle hues that help build consistent and visually appealing design systems.
				</p>
				<ToolsGrid
					client:load
					category="colour"
					initialTools={tools}
				/>
			</div>
		</section>
	</main>
</HomescreenLayout>
