---
import HomescreenLayout from "../layouts/homescreen.astro";
import ToolsGrid from "../components/tools-grid";
import { getToolsByCategory } from "@/lib/get-tool-by-category";

const tools = await getToolsByCategory("font");

if (Astro.cache.enabled) {
	Astro.cache.set({
		maxAge: 3600,
		tags: ["fonts-page"],
	});
}
---

<HomescreenLayout title="Font Resources for Designers | Design Index" description="Explore curated font resources including serif, sans-serif, display, and variable fonts for modern design systems." keywords="fonts, typefaces, variable fonts, typography resources, serif fonts, sans serif fonts" backgroundVariant="slate">
	<main class="mt-[40px] md:mt-[30px] px-[20px]">
		<section>
			<div>
				<h1 class="mt-3 font-departure font-regular text-4xl leading-none theme-text-primary md:text-[40px]">FONTS</h1>
				<p class="hidden md:block mt-4 rounded-lg border border-[var(--app-border)] bg-[var(--app-surface-soft)] px-[10px] py-[5px] font-departure text-sm leading-[20px] theme-text-muted md:text-base">
					A handpicked selection of font libraries to bring personality and clarity to your typography. Whether you're looking for elegant serifs, modern sans-serifs, or expressive display fonts, this section helps you find the perfect typeface to elevate your design language and reinforce brand identity.
				</p>
				<p class="block md:hidden mt-4 rounded-lg border border-[var(--app-border)] bg-[var(--app-surface-soft)] px-[10px] py-[5px] font-departure text-sm leading-[20px] theme-text-muted md:text-base">
					A handpicked collection of fonts to add personality and clarity to your typography. From elegant serifs to bold display fonts, find the perfect typeface to elevate your design and brand. typeface to elevate your design language and reinforce brand identity.
				</p>
				<ToolsGrid client:load category="font" initialTools={tools} />
			</div>
		</section>
	</main>
</HomescreenLayout>
