---
const filters = [
  { value: "free", label: "FREE" },
  { value: "paid", label: "PAID" },
  { value: "all", label: "FREE & PAID" },
];
---

<div class="mt-5" data-pricing-filter>
  <p class="mb-2 font-rethink font-bold text-[11px] uppercase tracking-[0.16em] theme-text-soft">Filter by pricing</p>
  <div class="flex flex-wrap gap-2">
    {
      filters.map((filter, index) => (
        <button
          type="button"
          data-filter={filter.value}
          aria-pressed={index === 2 ? "true" : "false"}
          class={`rounded-[10px] border px-3 py-1.5 font-rethink font-bold text-xs transition-colors ${
            index === 2
              ? "border-[var(--app-text)] bg-[var(--app-text)] text-[var(--app-bg)]"
              : "border-[var(--app-border)] bg-[var(--app-surface-soft)] theme-text-muted hover:border-[var(--app-border-strong)] hover:theme-text-primary"
          }`}
        >
          {filter.label}
        </button>
      ))
    }
  </div>
</div>