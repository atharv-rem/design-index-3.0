---
import '../styles/global.css';
import HomeSidebar from '../components/home-sidebar';
import SiteFooter from '../components/site-footer.astro';
import { Font, Picture } from 'astro:assets';
import backgroundImage from '../images/background_dark.jpg';
import mobileBackgroundImage from '../images/background_dark_mobile.png';
import backgroundLightImage from '../images/background_light.png';
import mobileBackgroundLightImage from '../images/background_light_mobile.png';

type Props = {
    title?: string;
    description?: string;
    keywords?: string;
    noindex?: boolean;
    ogType?: 'website' | 'article';
    backgroundVariant?: 'image' | 'slate';
    showDefaultSidebarTrigger?: boolean;
    floatingNavbarSocialLinks?: Array<{ label: string; href: string; icon: string }>;
    showFooter?: boolean;
    visitUrl?: string;
    shareTitle?: string;
};

const {
    title = 'Design Index | Curated Design Tools, Resources, and Inspiration',
    description = 'Discover curated design tools, mockups, icons, fonts, color resources, and inspiration in one fast searchable index.',
    keywords = 'design tools, design resources, mockups, icons, fonts, color palettes, design inspiration, UI resources',
    noindex = false,
    ogType = 'website',
    backgroundVariant = 'image',
    showDefaultSidebarTrigger = false,
    floatingNavbarSocialLinks = [],
    showFooter = true,
    visitUrl,
    shareTitle,
} = Astro.props;

const canonicalUrl = Astro.url.href;
const ogImage = new URL('/favicon.svg', Astro.url).href;
const faviconVersion = '20260331';
const faviconSvg = `/favicon.svg?v=${faviconVersion}`;
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <script
            src="https://cdn.databuddy.cc/databuddy.js"
            data-client-id="CzkF34Qr773cOXFFoHjzM"
            crossorigin="anonymous"
            async
        ></script>
        <link rel="icon" type="image/svg+xml" href={faviconSvg} />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <meta name="description" content={description} />
        <meta name="keywords" content={keywords} />
        <meta name="author" content="Atharv Remeshan" />
        <meta name="robots" content={noindex ? 'noindex,nofollow' : 'index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1'} />
        <meta name="theme-color" content="#000000" />
        <link rel="canonical" href={canonicalUrl} />
        <link rel="sitemap" href="/sitemap-index.xml" />

        <meta property="og:type" content={ogType} />
        <meta property="og:site_name" content="Design Index" />
        <meta property="og:locale" content="en_US" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:image" content={ogImage} />
        <meta property="og:image:alt" content="Design Index" />

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImage} />
        <meta name="twitter:image:alt" content="Design Index" />
        <script is:inline>
            (() => {
                const storageKey = 'design-index-theme';
                const root = document.documentElement;
                const storedTheme = localStorage.getItem(storageKey);
                const isDark = storedTheme ? storedTheme === 'dark' : true;

                root.classList.toggle('dark', isDark);
                root.dataset.theme = isDark ? 'dark' : 'light';

                const metaTheme = document.querySelector('meta[name="theme-color"]');
                if (metaTheme) {
                    metaTheme.setAttribute('content', isDark ? '#000000' : '#ffffff');
                }
            })();
        </script>
        <Font cssVariable="--font-kalamayka" />
        <Font cssVariable="--departure" />
    </head>
    <body class={`theme-body-bg relative min-h-screen font-kal ${backgroundVariant === 'slate' ? 'theme-solid-bg' : ''}`}>
        {
            backgroundVariant === 'image' ? (
                <div class="bg-fixed-container fixed inset-0 -z-10">
                    <Picture
                        src={mobileBackgroundLightImage}
                        formats={['avif', 'webp']}
                        alt=""
                        quality={55}
                        widths={[360, 480, 640, 768]}
                        sizes="100vw"
                        loading="eager"
                        class="theme-light-image h-full w-full object-cover object-center md:hidden"
                    />
                    <Picture
                        src={backgroundLightImage}
                        formats={['avif', 'webp']}
                        alt=""
                        quality={55}
                        widths={[640, 960, 1280, 1600]}
                        sizes="100vw"
                        loading="eager"
                        class="theme-light-image hidden h-full w-full object-cover object-[60%_center] md:block md:object-center"
                    />
                    <Picture
                        src={mobileBackgroundImage}
                        formats={['avif', 'webp']}
                        alt=""
                        quality={55}
                        widths={[360, 480, 640, 768]}
                        sizes="100vw"
                        loading="eager"
                        class="theme-dark-image h-full w-full object-cover object-center md:hidden"
                    />
                    <Picture
                        src={backgroundImage}
                        formats={['avif', 'webp']}
                        alt=""
                        quality={55}
                        widths={[640, 960, 1280, 1600]}
                        sizes="100vw"
                        loading="eager"
                        class="theme-dark-image hidden h-full w-full object-cover object-[60%_center] md:block md:object-center"
                    />
                </div>
            ) : (
                <div class="theme-solid-bg fixed inset-0 -z-10" />
            )
        }
        <HomeSidebar
            client:load
            showDefaultTrigger={showDefaultSidebarTrigger}
            floatingNavbarSocialLinks={floatingNavbarSocialLinks}
            visitUrl={visitUrl}
            shareTitle={shareTitle}
        >
            <slot />
            {showFooter && <SiteFooter />}
        </HomeSidebar>
    </body>
</html>
