---
import '../styles/global.css';
import HomeSidebar from '../components/home-sidebar';
import { Font, Picture } from 'astro:assets';
import backgroundImage from '../images/background.jpg';
import mobileBackgroundImage from '../images/background mobile.png';

type Props = {
    title?: string;
    description?: string;
    keywords?: string;
    noindex?: boolean;
    ogType?: 'website' | 'article';
    backgroundVariant?: 'image' | 'slate';
    showDefaultSidebarTrigger?: boolean;
    floatingNavbarSocialLinks?: Array<{ label: string; href: string; icon: string }>;
    floatingNavbarMode?: 'brand' | 'search';
    floatingNavbarSearchPlaceholder?: string;
};

const {
    title = 'Design Index | Curated Design Tools, Resources, and Inspiration',
    description = 'Discover curated design tools, mockups, icons, fonts, color resources, and inspiration in one fast searchable index.',
    keywords = 'design tools, design resources, mockups, icons, fonts, color palettes, design inspiration, UI resources',
    noindex = false,
    ogType = 'website',
    backgroundVariant = 'image',
    showDefaultSidebarTrigger = false,
    floatingNavbarSocialLinks = [],
    floatingNavbarMode = 'brand',
    floatingNavbarSearchPlaceholder = 'Search design tools...',
} = Astro.props;

const canonicalUrl = Astro.url.href;
const ogImage = new URL('/favicon.svg', Astro.url).href;
const faviconVersion = '20260331';
const faviconSvg = `/favicon.svg?v=${faviconVersion}`;
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href={faviconSvg} />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <meta name="description" content={description} />
        <meta name="keywords" content={keywords} />
        <meta name="author" content="Atharv Remeshan" />
        <meta name="robots" content={noindex ? 'noindex,nofollow' : 'index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1'} />
        <meta name="theme-color" content="#000000" />
        <link rel="canonical" href={canonicalUrl} />

        <meta property="og:type" content={ogType} />
        <meta property="og:site_name" content="Design Index" />
        <meta property="og:locale" content="en_US" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:image" content={ogImage} />
        <meta property="og:image:alt" content="Design Index" />

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImage} />
        <meta name="twitter:image:alt" content="Design Index" />
        <Font cssVariable="--font-kalamayka" />
        <Font cssVariable="--departure" />
    </head>
    <body class={`relative min-h-screen font-kal ${backgroundVariant === 'slate' ? 'bg-[#0B0B0B]' : 'bg-black'}`}>
        {
            backgroundVariant === 'image' ? (
                <div class="fixed inset-0 -z-10">
                    <Picture
                        src={mobileBackgroundImage}
                        formats={['avif', 'webp']}
                        alt=""
                        quality={55}
                        widths={[360, 480, 640, 768]}
                        sizes="100vw"
                        loading="eager"
                        class="h-full w-full object-cover object-center md:hidden"
                    />
                    <Picture
                        src={backgroundImage}
                        formats={['avif', 'webp']}
                        alt=""
                        quality={55}
                        widths={[640, 960, 1280, 1600]}
                        sizes="100vw"
                        loading="eager"
                        class="hidden h-full w-full object-cover object-[60%_center] md:block md:object-center"
                    />
                </div>
            ) : (
                <div class="fixed inset-0 -z-10 bg-[#0B0B0B]" />
            )
        }
        <HomeSidebar
            client:load
            showDefaultTrigger={showDefaultSidebarTrigger}
            floatingNavbarSocialLinks={floatingNavbarSocialLinks}
            floatingNavbarMode={floatingNavbarMode}
            floatingNavbarSearchPlaceholder={floatingNavbarSearchPlaceholder}
        >
            <slot />
        </HomeSidebar>
    </body>
</html>